# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
venv/
*.db
__pycache__/
.claude/
backend/.next/

# Firmware secrets (WiFi/MQTT credentials)
firmware/conveyor_controller/config.h

# Firmware debug sketches (temporary, not for production)
firmware/i2c_scan/
firmware/tof_protocol_scan/

# Firmware binary assets (>1MB, kept out of git)
firmware/conveyor_controller/wiring_diagram_full.png
firmware/conveyor_controller/wiring_diagram_image_only.png

# PyInstaller build outputs
monitoring/build/
monitoring/dist/

# Confluence sync (launchd)
logs/
docs/.confluence_snapshot.json

# pytest coverage data
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# mTLS certs (V6 S-001) — never commit private keys
backend/management/certs/
*.key
*.srl


# MQTT 인증 (V6 S-002)
backend/management/mosquitto/passwd
backend/management/mosquitto/passwd.bak
firmware/**/build/

# 로컬 DB 백업 — 추적 안 함 (용량 클 수 있음)
backups/

# OMC (oh-my-claudecode) workspace state — not versioned
.omc/
backend/.omc/
backend/management/.omc/
.omx/

# 바코드 테스트 산물 (바이너리·실측 로그) — 추적 안 함
tools/barcodes_out/
tools/barcodes_out_code39/
tools/barcode_bench_out/
