# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
venv/
*.db
__pycache__/
.claude/
backend/.next/

# Firmware secrets (WiFi/MQTT credentials)
firmware/conveyor_controller/config.h

# Firmware debug sketches (temporary, not for production)
firmware/i2c_scan/
firmware/tof_protocol_scan/

# Firmware binary assets (>1MB, kept out of git)
firmware/conveyor_controller/wiring_diagram_full.png
firmware/conveyor_controller/wiring_diagram_image_only.png

# PyInstaller build outputs
monitoring/build/
monitoring/dist/

# Confluence sync (launchd)
logs/
docs/.confluence_snapshot.json

# pytest coverage data
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# mTLS certs (V6 S-001) — never commit private keys
backend/management/certs/
*.key
*.srl

