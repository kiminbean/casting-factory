# /home/jetson/casting-image-publisher/env — systemd 에서 EnvironmentFile 로 로드
# 실제 배포 시 env.example → env 로 복사 후 값 채움
JETSON_CAMERA_ID=CAM-INSP-01
JETSON_CAMERA_INDEX=0
JETSON_FRAME_WIDTH=1280
JETSON_FRAME_HEIGHT=720
JETSON_FPS=2
JETSON_JPEG_QUALITY=85
# Management Server (Tailscale IP). 로컬 Mac 에서 서버 기동 시 해당 Mac Tailscale IP
MANAGEMENT_GRPC_HOST=100.107.120.xx
MANAGEMENT_GRPC_PORT=50051
MGMT_GRPC_TLS_ENABLED=0
# mTLS 활성 시 (옵션)
# MGMT_TLS_CA_CRT=/home/jetson/certs/ca.crt
# MGMT_TLS_CLIENT_CRT=/home/jetson/certs/jetson.crt
# MGMT_TLS_CLIENT_KEY=/home/jetson/certs/jetson.key
